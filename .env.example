# Devflow platform server configuration. Copy to .env and adjust as needed.

# MySQL DSN used by the platform store. Starts with `docker compose up -d mysql`.
DEVFLOW_DATABASE_DSN=devflow:devflow@tcp(127.0.0.1:3306)/devflow?parseTime=true

# Dev-mode identity. The server seeds this user and uses its role for RBAC
# until full authentication exists.
DEVFLOW_DEV_USER_EMAIL=admin@example.com
DEVFLOW_DEV_USER_ROLE=Admin